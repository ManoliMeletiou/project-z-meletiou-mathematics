{
  "name": "project-z-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "smoke": "node scripts/smoke-production.mjs",
    "verify:generator": "node --experimental-strip-types scripts/verify-golden-generator.mts",
    "test": "node --experimental-strip-types --test tests/*.test.mts",
    "typecheck": "tsc --noEmit",
    "check": "npm test && npm run verify:generator && npm run typecheck && npm run build && npm run smoke"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
